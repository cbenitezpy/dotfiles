# secrets/env.example — PLANTILLA (no contiene secretos reales).
# Los valores reales viven CIFRADOS en secrets/vars.sops.env
# (formato dotenv). Edita los reales con: ./secrets/manage.sh edit
#
# Formato: una variable por línea, KEY=value (sin `export`).
# Los valores pueden tener espacios sin comillas.
#
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
