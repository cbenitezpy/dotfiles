brew "fd"          # find
brew "ripgrep"     # grep
brew "bottom"      # top (btm)
brew "gping"       # ping with graph

# --- tmux / sessions ---
brew "sesh"        # smart tmux session manager (fzf + zoxide)

# --- Git ---
